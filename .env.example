# A generated secret for Payload
PAYLOAD_SECRET=

# Typesense search (optional — sync is disabled when TYPESENSE_HOST is empty)
TYPESENSE_HOST=aacflow.io
TYPESENSE_PORT=13000
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=aac

# Lago billing (optional — plugin is disabled when LAGO_API_KEY is empty)
# Plans/tariffs/subscriptions live in Lago; Payload never duplicates them
LAGO_API_URL=
LAGO_API_KEY=
# Billing webhooks (optional): expected `iss` claim of webhook JWTs — the ROOT
# url of the billing backend (defaults to the origin of LAGO_API_URL)
LAGO_WEBHOOK_ISSUER=
# Optional HMAC fallback key — set ONLY if the webhook endpoint is configured
# with signature_algo 'hmac' (default JWT needs no extra config)
LAGO_WEBHOOK_HMAC_KEY=

# Search-only Typesense key for per-tenant scoped search keys (optional)
TYPESENSE_SEARCH_ONLY_KEY=
# Scoped search key lifetime in seconds (optional, default 900)
SEARCH_KEY_TTL_SECONDS=

# Bearer secret for the jobs runner — external cron hits GET /api/payload-jobs/run
CRON_SECRET=

# Nango integrations (optional — disabled when NANGO_SECRET_KEY is empty)
NANGO_HOST=
NANGO_SECRET_KEY=
NANGO_WEBHOOK_KEY=

# Airbyte pipelines (optional — disabled when AIRBYTE_API_URL/TOKEN are empty)
AIRBYTE_API_URL=
AIRBYTE_API_TOKEN=
AIRBYTE_WORKSPACE_ID=

# Stripe payments (optional — plugin disabled when STRIPE_SECRET_KEY is empty)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOKS_SIGNING_SECRET=

# Sentry error reporting (optional — plugin disabled when SENTRY_DSN is empty)
SENTRY_DSN=

# AI admin assistants (optional)
# ANTHROPIC_API_KEY or OPENAI_API_KEY enables @ai-stack/payloadcms compose in pages.
# The media alt-text field is always present; its Generate button additionally
# needs OPENAI_API_KEY and a public NEXT_PUBLIC_SERVER_URL the model can fetch.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NEXT_PUBLIC_SERVER_URL=

# Transactional email via Cloudflare Email Sending (see wrangler.jsonc
# `send_email` binding — requires domain onboarding in the Cloudflare
# dashboard first). Falls back to a REPLACE_WITH_YOUR_DOMAIN placeholder.
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
