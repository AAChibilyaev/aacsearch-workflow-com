{
    "name": "aacsearch/sdk",
    "description": "AACSearch PayloadCMS v3 PHP SDK — search, collections, integrations & billing",
    "type": "library",
    "license": "MIT",
    "keywords": ["aacsearch", "search", "sdk", "payloadcms", "php"],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "AACSearch\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AACSearch\\SDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check": "php -l src/"
    }
}
