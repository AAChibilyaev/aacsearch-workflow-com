{
    "name": "@aacsearch/ui",
    "version": "1.0.0",
    "description": "AACSearch Instant Search UI — zero-config search widget for CDN",
    "type": "module",
    "main": "./dist/aacsearch-ui.js",
    "types": "./dist/aacsearch-ui.d.ts",
    "exports": {
        ".": {
            "types": "./dist/aacsearch-ui.d.ts",
            "import": "./dist/aacsearch-ui.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit"
    },
    "keywords": ["aacsearch", "search", "ui", "widget"],
    "license": "MIT",
    "dependencies": {
        "typesense": "^1.8.0",
        "typesense-instantsearch-adapter": "^3.0.0",
        "instantsearch.js": "^4.0.0"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.6.0"
    }
}
