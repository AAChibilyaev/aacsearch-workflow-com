{
  "name": "aacsearch-workflow-com",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:widget && opennextjs-cloudflare build",
    "build:widget": "pnpm --filter @aacsearch/ui build && mkdir -p public/widget && cp packages/aacsearch-ui/dist/aacsearch-ui.js public/widget/aacsearch-ui.js",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "pnpm run build && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && rm -rf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "preview": "pnpm run build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@ai-stack/payloadcms": "^3.2.28",
    "@elghaied/payload-plugin-notifications": "^1.0.0",
    "@jhb.software/payload-alt-text-plugin": "^0.8.0",
    "@nangohq/frontend": "^0.70.9",
    "@nangohq/node": "^0.70.9",
    "@opennextjs/cloudflare": "^1.20.1",
    "@payloadcms/db-d1-sqlite": "3.86.0",
    "@payloadcms/live-preview-react": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-ecommerce": "3.86.0",
    "@payloadcms/plugin-form-builder": "3.86.0",
    "@payloadcms/plugin-import-export": "3.86.0",
    "@payloadcms/plugin-mcp": "3.86.0",
    "@payloadcms/plugin-multi-tenant": "3.86.0",
    "@payloadcms/plugin-nested-docs": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-search": "3.86.0",
    "@payloadcms/plugin-sentry": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/plugin-stripe": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/sdk": "3.86.0",
    "@payloadcms/storage-r2": "3.86.0",
    "@payloadcms/translations": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@rubixstudios/payload-typesense": "1.6.11",
    "@sentry/nextjs": "^10.65.0",
    "@sentry/vercel-edge": "^10.65.0",
    "@veiag/payload-cmdk": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "graphql": "^16.14.2",
    "lago-javascript-client": "^1.49.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "15.4.11",
    "payload": "3.86.0",
    "payload-auditor": "^1.11.0",
    "payload-better-preview": "^2.1.3",
    "payload-cloudflare-email-adapter": "^1.0.0",
    "payload-oapi": "^0.2.5",
    "payload-totp": "^3.0.1",
    "radix-ui": "^1.6.2",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "typesense": "^3.0.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.7",
    "jsdom": "28.0.0",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.6",
    "wrangler": "~4.61.1"
  },
  "engines": {
    "node": ">=22.16.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
